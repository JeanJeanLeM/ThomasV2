CREATE TABLE public.profiles (
  id uuid NOT NULL,
  email character varying,
  first_name character varying,
  last_name character varying,
  full_name character varying DEFAULT 
CASE
    WHEN ((first_name IS NOT NULL) AND (last_name IS NOT NULL)) THEN ((((first_name)::text || ' '::text) || (last_name)::text))::character varying
    ELSE COALESCE(first_name, last_name, email)
END,
  avatar_url text,
  phone character varying,
  bio text,
  profession character varying,
  language character varying NOT NULL DEFAULT 'fr'::character varying,
  timezone character varying DEFAULT 'Europe/Paris'::character varying,
  notification_preferences jsonb NOT NULL DEFAULT '{"task_reminders": true, "farm_invitations": true, "marketing_emails": false, "push_notifications": true, "email_notifications": true}'::jsonb,
  created_at timestamp with time zone NOT NULL DEFAULT now(),
  updated_at timestamp with time zone NOT NULL DEFAULT now(),
  latest_active_farm_id integer,
  weekly_work_hours integer DEFAULT 35,
  primary_role character varying NOT NULL DEFAULT 'farmer'::character varying CHECK (primary_role::text = ANY (ARRAY['farmer'::character varying, 'advisor'::character varying, 'admin'::character varying, 'other'::character varying]::text[])),
  last_app_version text,
  last_build_version text,
  last_runtime_version text,
  last_update_id text,
  last_seen_at timestamp with time zone,
  CONSTRAINT profiles_pkey PRIMARY KEY (id),
  CONSTRAINT profiles_latest_active_farm_id_fkey FOREIGN KEY (latest_active_farm_id) REFERENCES public.farms(id)
);
